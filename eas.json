{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "default"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "default"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "default"
      }
    }
  }
}
